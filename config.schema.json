{
    "pluginAlias": "BlindsHTTP",
    "pluginType": "accessory",
    "singular": false,
    "headerDisplay": "Control HTTP-based blinds, shades, awnings, and shutters.\n\nFull documentation, tested device configurations (Tasmota, Bond, Louvolite, etc.), and bug reports: [github.com/dxdc/homebridge-blinds](https://github.com/dxdc/homebridge-blinds).\n\n**Quick tips:** include `%%POS%%` in any URL or body to inject the target position. Use a `file://` prefix to run a shell command instead of an HTTP request.",
    "schema": {
        "type": "object",
        "properties": {
            "name": {
                "title": "Accessory name",
                "type": "string",
                "required": true,
                "description": "Display name shown in the Home app."
            },
            "up_url": { "$ref": "#/$defs/http_options" },
            "down_url": { "$ref": "#/$defs/http_options" },
            "stop_url": { "$ref": "#/$defs/http_options" },
            "motion_time": {
                "title": "Motion Time (ms)",
                "type": "integer",
                "placeholder": 10000,
                "minimum": 1,
                "description": "Milliseconds for the motor to move from fully open to fully closed (or back). Used for both directions if motion_time_graph is not set."
            },
            "motion_time_graph": {
                "title": "Motion Time Mapping (advanced, optional)",
                "type": "object",
                "expandable": true,
                "properties": {
                    "up": { "$ref": "#/$defs/motion_graph_entry" },
                    "down": { "$ref": "#/$defs/motion_graph_entry" }
                },
                "description": "Per-direction, piecewise motion timing. Use this when blinds move at different speeds at different positions, or when up/down speeds differ. Each direction needs at least entries for pos 0 and pos 100; intermediate entries refine the curve. Takes precedence over motion_time when both are set."
            },
            "show_toggle_button": {
                "title": "Show Toggle (up/down) Button",
                "type": "boolean",
                "description": "Adds a HomeKit switch that flips the blinds based on the most recent up/down command."
            },
            "show_stop_button": {
                "title": "Show Stop Button",
                "type": "boolean",
                "description": "Adds a HomeKit switch that sends the configured stop URL."
            },
            "use_same_url_for_stop": {
                "title": "Use Up/Down URL as Stop",
                "type": "boolean",
                "description": "Re-send the most recent up_url or down_url instead of stop_url. Useful for blinds that toggle on a single endpoint."
            },
            "trigger_stop_at_boundaries": {
                "title": "Send Stop at Boundaries",
                "type": "boolean",
                "description": "Send a stop command even when moving to fully open or fully closed. Most blinds stop themselves at boundaries; only enable this if yours do not."
            },
            "pos_url": {
                "title": "Position URL",
                "type": "string",
                "description": "URL polled to learn the real blind position. Must return a value 0–100 (use pos_jsonata to extract it from larger payloads).",
                "placeholder": "http://1.2.3.4/window/position",
                "format": "uri"
            },
            "pos_poll_ms": {
                "title": "Position polling interval (ms)",
                "type": "integer",
                "description": "How often to poll the position URL. Minimum 5000 ms.",
                "minimum": 5000,
                "placeholder": 15000
            },
            "pos_jsonata": {
                "title": "JSONata for Position URL response",
                "type": "string",
                "description": "JSONata expression that extracts the position (0-100) from the response body. Example: `ShutterPosition1` returns the value of that field.",
                "placeholder": "ShutterPosition1"
            },
            "send_pos_jsonata": {
                "title": "JSONata for outbound %%POS%%",
                "type": "string",
                "description": "Optional JSONata expression that maps the HomeKit target (0-100) to whatever value the device expects before substituting into %%POS%%. Example below scales 0-100 to the inverted 0-255 range.",
                "placeholder": "$round( ( 100 - $number($) ) * 255 / 100 )"
            },
            "response_lag_ms": {
                "title": "Response Lag (ms)",
                "type": "integer",
                "placeholder": 0,
                "minimum": 0,
                "description": "Delay between sending the move command and the motor actually starting. Improves position accuracy when the device or RF link adds latency."
            },
            "request_timeout_ms": {
                "title": "Request timeout (ms)",
                "type": "integer",
                "placeholder": 10000,
                "minimum": 100,
                "description": "Per-attempt HTTP timeout. Lower this so an unreachable device fails fast instead of stalling Homebridge."
            },
            "command_repeat_count": {
                "title": "Command repeat count",
                "type": "integer",
                "placeholder": 1,
                "minimum": 1,
                "maximum": 10,
                "description": "Send each move command this many times. Useful for unreliable RF blinds where the first command sometimes does not register."
            },
            "obstruction_threshold": {
                "title": "Obstruction threshold",
                "type": "integer",
                "placeholder": 1,
                "minimum": 1,
                "description": "Consecutive failed requests required before HomeKit shows the blind as obstructed. Default 1 (trip immediately). Increase to filter out brief network blips."
            },
            "set_debounce_ms": {
                "title": "Slider debounce (ms)",
                "type": "integer",
                "placeholder": 0,
                "minimum": 0,
                "description": "Wait this long after the last position change before issuing the move command. Coalesces a burst of HomeKit events (e.g. while dragging the slider in the Home app) into a single request. 0 disables debouncing."
            },
            "battery_url": {
                "title": "Battery URL",
                "type": "string",
                "format": "uri",
                "placeholder": "http://1.2.3.4/blind/battery",
                "description": "Optional URL polled to read the blind's battery level. Must return a 0-100 integer (use battery_jsonata to extract from a larger payload)."
            },
            "battery_poll_ms": {
                "title": "Battery polling interval (ms)",
                "type": "integer",
                "placeholder": 300000,
                "minimum": 30000,
                "description": "Milliseconds between battery polls. Default 5 minutes; minimum 30 seconds. Battery levels typically change slowly so a long interval is fine."
            },
            "battery_jsonata": {
                "title": "JSONata for battery URL response",
                "type": "string",
                "placeholder": "BatteryLevel"
            },
            "battery_low_threshold": {
                "title": "Low-battery threshold (%)",
                "type": "integer",
                "placeholder": 20,
                "minimum": 0,
                "maximum": 100,
                "description": "iOS shows the low-battery indicator when BatteryLevel is at or below this value."
            },
            "http_success_codes": {
                "type": "array",
                "notitle": true,
                "uniqueItems": true,
                "displayFlex": true,
                "flex-direction": "row",
                "items": {
                    "type": "integer",
                    "placeholder": 200,
                    "minimum": 1
                }
            },
            "show_favorite_buttons": {
                "type": "array",
                "notitle": true,
                "uniqueItems": true,
                "displayFlex": true,
                "flex-direction": "row",
                "items": {
                    "type": "integer",
                    "title": "Position (0 = closed, 100 = open)",
                    "placeholder": 50,
                    "minimum": 0,
                    "maximum": 100
                }
            },
            "webhook_port": {
                "title": "Port",
                "type": "integer",
                "placeholder": 51828,
                "minimum": 1,
                "maximum": 65535
            },
            "webhook_http_auth_user": {
                "title": "Username",
                "type": "string"
            },
            "webhook_http_auth_pass": {
                "title": "Password",
                "type": "string"
            },
            "webhook_https": {
                "title": "Use SSL",
                "type": "boolean"
            },
            "webhook_https_keyfile": {
                "title": "Path to private key",
                "type": "string"
            },
            "webhook_https_certfile": {
                "title": "Path to certificate",
                "type": "string"
            },
            "invert_position": {
                "title": "Invert Position",
                "type": "boolean",
                "description": "Swap the 0% and 100% endpoints in HomeKit. Common for awnings or shades where 'closed' physically means extended/down."
            },
            "unique_serial": {
                "title": "Use unique serial",
                "type": "boolean",
                "description": "Use a UUID-derived serial/model instead of the default 'BlindsHTTPAccessory'. Only required for integrations (e.g., Eve) that demand distinct serials per accessory."
            },
            "verbose": {
                "title": "Verbose logging",
                "type": "boolean",
                "description": "Log additional diagnostics: every poll, motion calculations, JSON parse errors, etc."
            }
        },
        "$defs": {
            "motion_graph_entry": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "pos": {
                            "title": "Position (0 = closed, 100 = open)",
                            "type": "integer",
                            "placeholder": 0,
                            "minimum": 0,
                            "maximum": 100,
                            "required": true
                        },
                        "seconds": {
                            "title": "Elapsed seconds",
                            "type": "number",
                            "minimum": 0,
                            "placeholder": 0.0,
                            "required": true
                        }
                    }
                }
            },
            "http_options": {
                "type": "object",
                "properties": {
                    "url": {
                        "title": "URL",
                        "type": "string",
                        "placeholder": "http://1.2.3.4/window/cmnd",
                        "description": "May include %%POS%% (replaced with the integer target position) or `\"%%POSINT%%\"` (replaced as a raw JSON number, dropping the surrounding quotes). Prefix with `file://` to run a shell command instead.",
                        "format": "uri"
                    },
                    "method": {
                        "title": "HTTP Method",
                        "type": "string",
                        "placeholder": "POST",
                        "oneOf": [
                            { "title": "GET", "type": "string" },
                            { "title": "POST", "type": "string" },
                            { "title": "PUT", "type": "string" },
                            { "title": "PATCH", "type": "string" },
                            { "title": "DELETE", "type": "string" }
                        ],
                        "typeahead": {
                            "source": ["GET", "POST", "PUT", "PATCH", "DELETE"]
                        }
                    },
                    "headers": {
                        "type": "object",
                        "title": "Headers",
                        "properties": {
                            "Authorization": { "type": "string" },
                            "BOND-Token": { "type": "string" }
                        }
                    },
                    "body": {
                        "title": "HTTP Body",
                        "type": "string",
                        "description": "Request body sent for non-GET methods. Supports %%POS%% / %%POSINT%% substitution."
                    },
                    "maxAttempts": {
                        "title": "Maximum HTTP attempts",
                        "type": "integer",
                        "minimum": 1,
                        "placeholder": 5
                    },
                    "retryDelay": {
                        "title": "Delay (ms) between attempts",
                        "type": "integer",
                        "minimum": 0,
                        "placeholder": 2000,
                        "description": "Base delay; the actual wait grows exponentially per retry."
                    },
                    "timeout": {
                        "title": "Per-attempt timeout (ms)",
                        "type": "integer",
                        "minimum": 100,
                        "placeholder": 10000
                    }
                }
            }
        }
    },
    "layout": [
        "name",
        {
            "title": "Up URL",
            "type": "fieldset",
            "expandable": true,
            "items": [
                {
                    "type": "help",
                    "helpvalue": "<p class='text-muted'>Tip: include <span class='text-info'>%%POS%%</span> in the URL or body to inject the target position. Use <span class='text-info'>file://</span> for shell scripts.</p>"
                },
                "up_url.url",
                "up_url.method",
                {
                    "key": "up_url.body",
                    "condition": {
                        "functionBody": "return model.up_url?.method && model.up_url.method !== 'GET'"
                    }
                },
                {
                    "type": "fieldset",
                    "title": "Headers",
                    "expandable": false,
                    "items": [
                        {
                            "type": "div",
                            "displayFlex": true,
                            "flex-direction": "row",
                            "items": [
                                { "key": "up_url.headers.Authorization", "flex": "1 1 50px" },
                                { "key": "up_url.headers.BOND-Token", "flex": "1 1 50px" }
                            ]
                        }
                    ]
                },
                "up_url.maxAttempts",
                "up_url.retryDelay",
                "up_url.timeout"
            ]
        },
        {
            "title": "Down URL",
            "type": "fieldset",
            "expandable": true,
            "items": [
                {
                    "type": "help",
                    "helpvalue": "<p class='text-muted'>Tip: include <span class='text-info'>%%POS%%</span> in the URL or body to inject the target position. Use <span class='text-info'>file://</span> for shell scripts.</p>"
                },
                "down_url.url",
                "down_url.method",
                {
                    "key": "down_url.body",
                    "condition": {
                        "functionBody": "return model.down_url?.method && model.down_url.method !== 'GET'"
                    }
                },
                {
                    "type": "fieldset",
                    "title": "Headers",
                    "expandable": false,
                    "items": [
                        {
                            "type": "div",
                            "displayFlex": true,
                            "flex-direction": "row",
                            "items": [
                                { "key": "down_url.headers.Authorization", "flex": "1 1 50px" },
                                { "key": "down_url.headers.BOND-Token", "flex": "1 1 50px" }
                            ]
                        }
                    ]
                },
                "down_url.maxAttempts",
                "down_url.retryDelay",
                "down_url.timeout"
            ]
        },
        {
            "title": "Stop URL",
            "expandable": true,
            "type": "fieldset",
            "items": [
                "stop_url.url",
                "stop_url.method",
                {
                    "key": "stop_url.body",
                    "condition": {
                        "functionBody": "return model.stop_url?.method && model.stop_url.method !== 'GET'"
                    }
                },
                {
                    "type": "fieldset",
                    "title": "Headers",
                    "expandable": false,
                    "items": [
                        {
                            "type": "div",
                            "displayFlex": true,
                            "flex-direction": "row",
                            "items": [
                                { "key": "stop_url.headers.Authorization", "flex": "1 1 50px" },
                                { "key": "stop_url.headers.BOND-Token", "flex": "1 1 50px" }
                            ]
                        }
                    ]
                },
                "stop_url.maxAttempts",
                "stop_url.retryDelay",
                "stop_url.timeout",
                {
                    "type": "flex",
                    "flex-flow": "row wrap",
                    "items": [
                        {
                            "key": "trigger_stop_at_boundaries",
                            "condition": {
                                "functionBody": "return model.trigger_stop_at_boundaries || model.stop_url?.url || model.use_same_url_for_stop"
                            }
                        },
                        {
                            "key": "use_same_url_for_stop",
                            "condition": {
                                "functionBody": "return model.use_same_url_for_stop || ((model.down_url?.url || model.up_url?.url) && !model.stop_url?.url)"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "title": "Outbound position mapping",
            "description": "Map the target position (0-100) before injecting it into %%POS%% / %%POSINT%%. Useful for devices that expect inverted or scaled values.",
            "type": "fieldset",
            "expandable": true,
            "items": ["send_pos_jsonata"]
        },
        {
            "title": "Position URL (poll device)",
            "description": "Optional: poll the device for its real position. The plugin emulates motion via timer if this is omitted.",
            "type": "fieldset",
            "expandable": true,
            "items": [
                "pos_url",
                {
                    "key": "pos_poll_ms",
                    "condition": {
                        "functionBody": "return model.pos_poll_ms || model.pos_url"
                    }
                },
                {
                    "key": "pos_jsonata",
                    "condition": {
                        "functionBody": "return model.pos_jsonata || model.pos_url"
                    }
                }
            ]
        },
        {
            "title": "Position Webhook (push from device)",
            "description": "Optional: run an HTTP listener that accepts position updates pushed from the device or another automation. Send any HTTP method to /?pos=N (sets current+target) or /?target=N (sets target only, no motor command). Values are 0-100.",
            "type": "fieldset",
            "expandable": true,
            "items": [
                "webhook_port",
                {
                    "type": "help",
                    "helpvalue": "<span class='text-info'>Optional Basic Authentication</span>"
                },
                "webhook_http_auth_user",
                "webhook_http_auth_pass",
                "webhook_https",
                {
                    "key": "webhook_https_keyfile",
                    "condition": {
                        "functionBody": "return model.webhook_https_keyfile || model.webhook_https_certfile || model.webhook_https"
                    }
                },
                {
                    "key": "webhook_https_certfile",
                    "condition": {
                        "functionBody": "return model.webhook_https_certfile || model.webhook_https_keyfile || model.webhook_https"
                    }
                }
            ]
        },
        {
            "title": "Motion Timing & Calibration",
            "description": "Tune how long the plugin waits for blinds to physically reach their target.",
            "type": "fieldset",
            "expandable": true,
            "items": [
                {
                    "key": "motion_time",
                    "condition": {
                        "functionBody": "return !model.motion_time_graph?.up && !model.motion_time_graph?.down"
                    }
                },
                "response_lag_ms",
                {
                    "type": "help",
                    "helpvalue": "<span class='text-info'>motion_time_graph takes precedence over motion_time. Each direction must include entries for pos = 0 and pos = 100; intermediate entries describe non-linear motion.</span>"
                },
                {
                    "key": "motion_time_graph.up",
                    "type": "array",
                    "title": "Motion Timing: Up",
                    "expandable": false,
                    "items": [
                        {
                            "type": "div",
                            "displayFlex": true,
                            "flex-direction": "row",
                            "items": [
                                { "key": "motion_time_graph.up[].pos", "flex": "1 1 50px" },
                                { "key": "motion_time_graph.up[].seconds", "flex": "1 1 50px" }
                            ],
                            "minItems": 2
                        }
                    ]
                },
                {
                    "key": "motion_time_graph.down",
                    "type": "array",
                    "title": "Motion Timing: Down",
                    "expandable": false,
                    "items": [
                        {
                            "type": "div",
                            "displayFlex": true,
                            "flex-direction": "row",
                            "items": [
                                { "key": "motion_time_graph.down[].pos", "flex": "1 1 50px" },
                                { "key": "motion_time_graph.down[].seconds", "flex": "1 1 50px" }
                            ],
                            "minItems": 2
                        }
                    ]
                }
            ]
        },
        {
            "type": "fieldset",
            "expandable": true,
            "title": "HomeKit Buttons",
            "items": [
                {
                    "type": "flex",
                    "flex-flow": "row wrap",
                    "items": [
                        {
                            "key": "show_toggle_button",
                            "condition": {
                                "functionBody": "return model.show_toggle_button || (model.up_url?.url && model.down_url?.url)"
                            }
                        },
                        {
                            "key": "show_stop_button",
                            "condition": {
                                "functionBody": "return model.show_stop_button || model.use_same_url_for_stop || model.stop_url?.url"
                            }
                        }
                    ]
                },
                {
                    "type": "array",
                    "items": ["show_favorite_buttons[]"]
                }
            ]
        },
        {
            "title": "Battery (optional)",
            "description": "Surface a HomeKit Battery service that polls a URL on the device.",
            "type": "fieldset",
            "expandable": true,
            "items": [
                "battery_url",
                {
                    "key": "battery_jsonata",
                    "condition": { "functionBody": "return model.battery_url || model.battery_jsonata" }
                },
                {
                    "key": "battery_poll_ms",
                    "condition": { "functionBody": "return model.battery_url || model.battery_poll_ms" }
                },
                {
                    "key": "battery_low_threshold",
                    "condition": { "functionBody": "return model.battery_url || model.battery_low_threshold" }
                }
            ]
        },
        {
            "title": "Reliability & retries",
            "type": "fieldset",
            "expandable": true,
            "items": [
                "request_timeout_ms",
                "command_repeat_count",
                "obstruction_threshold",
                "set_debounce_ms",
                {
                    "type": "fieldset",
                    "title": "HTTP success codes",
                    "expandable": true,
                    "description": "List of HTTP codes treated as success. Defaults to [200].",
                    "items": [
                        {
                            "type": "array",
                            "items": ["http_success_codes[]"],
                            "minItems": 1
                        }
                    ]
                }
            ]
        },
        {
            "title": "Optional Parameters",
            "type": "fieldset",
            "expandable": true,
            "items": ["invert_position", "verbose", "unique_serial"]
        }
    ]
}
